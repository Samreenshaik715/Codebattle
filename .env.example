# =============================================================================
# CodeBattle - Root Environment Variables
# Copy to .env and adjust values for local development
# =============================================================================

# Application
NODE_ENV=development

# Backend
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000

# Database (PostgreSQL)
POSTGRES_USER=codebattle
POSTGRES_PASSWORD=codebattle_secret
POSTGRES_DB=codebattle
DATABASE_URL=postgresql://codebattle:codebattle_secret@localhost:5432/codebattle?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=30d

# CORS
# Allow localhost frontend origins for local development. Vite may increment the port if 5173 is already occupied.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
