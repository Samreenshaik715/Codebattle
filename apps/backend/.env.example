# =============================================================================
# CodeBattle Backend Environment Variables
# =============================================================================

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://codebattle:codebattle_secret@localhost:5432/codebattle?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:5173
