generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  passwordHash  String         @map("password_hash")
  rating        Int            @default(1200)
  wins          Int            @default(0)
  losses        Int            @default(0)
  isAdmin       Boolean        @default(false) @map("is_admin")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  battleLosses  BattleResult[] @relation("BattleLoser")
  battleWins    BattleResult[] @relation("BattleWinner")
  ownedRooms    BattleRoom[]   @relation("RoomOwner")
  refreshTokens RefreshToken[]
  roomPlayers   RoomPlayer[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Problem {
  id                String       @id @default(cuid())
  title             String
  description       String
  difficulty        Difficulty
  topic             String
  examples          Json
  constraints       String[]
  sampleInput       String?      @map("sample_input")
  sampleOutput      String?      @map("sample_output")
  boilerplate       Json
  createdAt         DateTime     @default(now()) @map("created_at")
  functionSignature String?      @map("function_signature")
  parameterTypes    Json?        @map("parameter_types")
  returnType        String?      @map("return_type")
  starterCode       Json?        @map("starter_code")
  battleRooms       BattleRoom[]
  testCases         TestCase[]

  @@index([difficulty])
  @@index([topic])
  @@map("problems")
}

model TestCase {
  id             String   @id @default(cuid())
  questionId     String   @map("question_id")
  input          String
  expectedOutput String   @map("expected_output")
  isHidden       Boolean  @default(false) @map("is_hidden")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  executionInput String?  @map("execution_input")
  problem        Problem  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("test_cases")
}

model BattleResult {
  id             String     @id @default(cuid())
  roomId         String     @unique @map("room_id")
  winnerId       String     @map("winner_id")
  loserId        String     @map("loser_id")
  winnerTime     Int        @map("winner_time")
  loserTime      Int?       @map("loser_time")
  creditsAwarded Int        @default(0) @map("credits_awarded")
  createdAt      DateTime   @default(now()) @map("created_at")
  loser          User       @relation("BattleLoser", fields: [loserId], references: [id], onDelete: Cascade)
  room           BattleRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  winner         User       @relation("BattleWinner", fields: [winnerId], references: [id], onDelete: Cascade)

  @@index([winnerId])
  @@index([loserId])
  @@map("battle_results")
}

model BattleRoom {
  id            String        @id @default(cuid())
  roomCode      String        @unique @map("room_code")
  ownerId       String        @map("owner_id")
  status        RoomStatus    @default(WAITING)
  problemId     String?       @map("problem_id")
  difficulty    Difficulty?
  topic         String?
  timerDuration Int?          @map("timer_duration")
  startedAt     DateTime?     @map("started_at")
  endedAt       DateTime?     @map("ended_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  results       BattleResult?
  owner         User          @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  problem       Problem?      @relation(fields: [problemId], references: [id])
  players       RoomPlayer[]

  @@index([ownerId])
  @@index([status])
  @@index([problemId])
  @@map("battle_rooms")
}

model RoomPlayer {
  id             String     @id @default(cuid())
  roomId         String     @map("room_id")
  userId         String     @map("user_id")
  isReady        Boolean    @default(false) @map("is_ready")
  selectedTopic  String?    @map("selected_topic")
  joinedAt       DateTime   @default(now()) @map("joined_at")
  finishedAt     DateTime?  @map("finished_at")
  solvedCount    Int        @default(0) @map("solved_count")
  totalSolveTime Int        @default(0) @map("total_solve_time")
  room           BattleRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("room_players")
}

enum RoomStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProgrammingLanguage {
  JAVA
  PYTHON
  CPP
  JAVASCRIPT
}
